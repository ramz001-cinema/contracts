{
	"name": "@ramz001-cinema/contracts",
	"version": "2.0.5",
	"description": "It contains the protobuf definitions and generated TypeScript code for the microservices communication",
	"scripts": {
		"build": "tsc",
		"generate": "protoc -I ./proto ./proto/*.proto --ts_proto_out=./src/gen --ts_proto_opt=nestJs=true,package=omit",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"format": "prettier --write \"src/**/*.ts\""
	},
	"keywords": [
		"protobuf",
		"nestjs",
		"microservices",
		"communication",
		"contracts"
	],
	"author": {
		"name": "Ramzbek",
		"email": "rkenjaev1@gmail.com"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"require": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"proto",
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT",
	"packageManager": "pnpm@10.13.1",
	"dependencies": {
		"@grpc/grpc-js": "^1.14.3",
		"@nestjs/microservices": "^11.1.17",
		"@ramz001-cinema/core": "^1.0.7",
		"jiti": "^2.6.1",
		"prettier": "^3.8.3",
		"protobufjs": "^8.0.0",
		"rxjs": "^7.8.2",
		"ts-proto": "^2.11.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.5.0",
		"eslint": "^10.2.0",
		"globals": "^17.5.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.2"
	}
}
